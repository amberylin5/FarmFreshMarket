@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Check for password expiry from TempData (set in Index.cshtml.cs) -->
@if (TempData["PasswordExpiredWarning"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>Password Expired!</strong>
        @TempData["PasswordExpiredWarning"]
        <a href="/ChangePassword" class="alert-link">Change Password Now</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["MultipleSessionsWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["MultipleSessionsWarning"]
        <a href="/ManageSessions" class="alert-link">Manage Sessions</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["PasswordExpiredMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["PasswordExpiredMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<nav class="navbar navbar-light bg-light mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Fresh Farm Market</a>
        <div>
            @if (User.Identity.IsAuthenticated)
            {
                <div class="dropdown">
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-user me-1"></i> @User.Identity.Name
                    </button>
                    <ul class="dropdown-menu">
                        @if (User.IsInRole("Admin"))
                        {
                            <li>
                                <a class="dropdown-item" href="/Admin">
                                    <i class="fas fa-shield-alt me-2"></i>Admin Panel
                                </a>
                            </li>
                        }
                        <li>
                            <a class="dropdown-item" href="/ChangePassword">
                                <i class="fas fa-key me-2"></i>Change Password
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/ManageSessions">
                                <i class="fas fa-desktop me-2"></i>Manage Sessions
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/Manage2FA">
                                <i class="fas fa-shield-alt me-2"></i>Manage 2FA
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="/Logout">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </a>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a href="/Login" class="btn btn-outline-primary btn-sm me-2">Login</a>
                <a href="/Register" class="btn btn-primary btn-sm">Register</a>
            }
        </div>
    </div>
</nav>

<div class="container">
    <div class="text-center">
        <h1 class="display-4">Welcome</h1>

        @if (User.Identity.IsAuthenticated)
        {
            @if (Model.LoggedInMember != null)
            {
                <div class="card mt-4" style="max-width: 600px; margin: 0 auto;">
                    <div class="card-body">
                        <h3>Welcome @Model.LoggedInMember.FullName!</h3>

                        <div class="row mt-3">
                            <div class="col-md-6 text-start">
                                <p><strong>Email:</strong> @Model.LoggedInMember.Email</p>
                                <p><strong>Credit Card:</strong> @Model.LoggedInMember.EncryptedCreditCardNo</p>
                                <p><strong>Delivery Address:</strong> @Model.LoggedInMember.DeliveryAddress</p>
                                <p><strong>Mobile:</strong> @Model.LoggedInMember.MobileNo</p>
                                <p><strong>Gender:</strong> @Model.LoggedInMember.Gender</p>
                            </div>
                            <div class="col-md-6">
                                @if (!string.IsNullOrEmpty(Model.LoggedInMember.PhotoPath))
                                {
                                    <img src="@Model.LoggedInMember.PhotoPath" class="img-thumbnail mb-3" width="150" />
                                }
                            </div>
                        </div>

                        <!-- ADDED: About Me Section -->
                        <div class="mt-3 text-start">
                            <p><strong>About Me:</strong></p>
                            <div class="border p-2 bg-light rounded">
                                @if (!string.IsNullOrEmpty(Model.LoggedInMember.AboutMe))
                                {
                                    <!-- This shows the encoded version (e.g., &lt;script&gt;) -->
                                    @Model.LoggedInMember.AboutMe
                                }
                                else
                                {
                                    <span class="text-muted">No information provided.</span>
                                }
                            </div>
                        </div>

                        <!-- XSS Protection Note -->
                        @if (Model.LoggedInMember.AboutMe?.Contains("&lt;") == true ||
                                        Model.LoggedInMember.FullName?.Contains("&lt;") == true)
                        {
                            <div class="alert alert-info mt-3">
                                <small>
                                    <i class="fas fa-shield-alt"></i>
                                    <strong>XSS Protection Active:</strong>
                                    Script tags are encoded (e.g., &lt;script&gt;) and displayed as safe text.
                                </small>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <p>Profile information not found. Please complete your registration.</p>
                </div>
            }

            <div class="mt-4">
                <div class="row justify-content-center">
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Security Settings</h5>
                                <a href="/Manage2FA" class="btn btn-primary">
                                    <i class="fas fa-shield-alt"></i> Manage 2FA
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="mt-5">
                <p class="lead">Please login or register to access your account.</p>
                <div class="mt-3">
                    <a href="/Login" class="btn btn-primary btn-lg me-3">Login</a>
                    <a href="/Register" class="btn btn-outline-primary btn-lg">Register</a>
                </div>
            </div>
        }
    </div>
</div>