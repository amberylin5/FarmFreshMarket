@page
@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card text-center">
                <div class="card-header bg-info text-white">
                    <h3><i class="fas fa-check-circle"></i> Check Your Email</h3>
                </div>
                <div class="card-body py-5">
                    <!-- TEST LINK DISPLAY -->
                    @if (TempData["TestResetLink"] != null)
                    {
                        <div class="alert alert-warning">
                            <h6><i class="fas fa-exclamation-triangle"></i> For Testing Only</h6>
                            <p class="small mb-2">Reset link (copy and paste in browser):</p>
                            <div class="input-group mb-2">
                                <input type="text" class="form-control form-control-sm"
                                       id="resetLink" value="@TempData["TestResetLink"]" readonly>
                                <button class="btn btn-outline-secondary btn-sm"
                                        type="button" onclick="copyResetLink()">
                                    <i class="fas fa-copy"></i> Copy
                                </button>
                            </div>
                            <a href="@TempData["TestResetLink"]" class="btn btn-sm btn-primary">
                                <i class="fas fa-external-link-alt"></i> Open Reset Page
                            </a>
                        </div>
                    }

                    <i class="fas fa-envelope fa-4x text-info mb-4"></i>
                    <h4>Password Reset Email Sent</h4>
                    <p class="text-muted">
                        If your email address is registered, you will receive a password reset link.
                        Please check your email inbox and follow the instructions.
                    </p>

                    <div class="alert alert-light mt-4">
                        <h6><i class="fas fa-lightbulb"></i> Didn't receive the email?</h6>
                        <ul class="text-start small">
                            <li>Check your spam or junk folder</li>
                            <li>Make sure you entered the correct email address</li>
                            <li>Wait a few minutes and try again</li>
                        </ul>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="/Login" class="btn btn-primary">
                        <i class="fas fa-arrow-left"></i> Back to Login
                    </a>
                    <a href="/ForgotPassword" class="btn btn-outline-secondary ms-2">
                        <i class="fas fa-redo"></i> Try Again
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function copyResetLink() {
        var copyText = document.getElementById("resetLink");
        copyText.select();
        copyText.setSelectionRange(0, 99999); // For mobile devices
        navigator.clipboard.writeText(copyText.value).then(function() {
            alert("Reset link copied to clipboard!");
        });
    }
</script>