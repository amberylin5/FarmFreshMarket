@page
@model FarmFreshMarket.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="container text-center mt-5">
    @if (Model.StatusCode == 404)
    {
        <h1 class="display-1 text-warning">404</h1>
        <h2>Page Not Found</h2>
        <p>@Model.ErrorMessage</p>
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary">Go Back</a>
    }
    else if (Model.StatusCode == 403)
    {
        <h1 class="display-1 text-danger">403</h1>
        <h2>Access Denied</h2>
        <p>@Model.ErrorMessage</p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-4">
                <a href="/" class="btn btn-primary">Go Home</a>
                <a href="/Logout" class="btn btn-outline-danger">Logout</a>
            </div>
        }
        else
        {
            <div class="mt-4">
                <a href="/Login" class="btn btn-primary">Login</a>
                <a href="/" class="btn btn-outline-secondary">Go Home</a>
            </div>
        }
    }
    else if (Model.StatusCode == 500)
    {
        <h1 class="display-1 text-danger">500</h1>
        <h2>Internal Server Error</h2>
        <p>@Model.ErrorMessage</p>
        <div class="mt-4">
            <a href="/" class="btn btn-primary">Go Home</a>
            <a href="javascript:location.reload()" class="btn btn-outline-warning">Try Again</a>
        </div>
    }
    else
    {
        <h1 class="display-1 text-info">@Model.StatusCode</h1>
        <h2>Error</h2>
        <p>@Model.ErrorMessage</p>
        <a href="/" class="btn btn-primary">Go Home</a>
    }
</div>