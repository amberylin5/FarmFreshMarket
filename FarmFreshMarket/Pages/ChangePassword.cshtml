@page
@model FarmFreshMarket.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0"><i class="fas fa-key"></i> Change Password</h3>
                </div>
                <div class="card-body">
                    <!-- Password Age Warning/Info -->
                    @if (!string.IsNullOrEmpty(Model.PasswordAgeMessage))
                    {
                        <div class="alert @(Model.PasswordAgeMessage.Contains("WARNING") ? "alert-warning" : "alert-info")">
                            <i class="fas fa-info-circle"></i> @Model.PasswordAgeMessage
                        </div>
                    }

                    <!-- Password Requirements -->
                    <div class="alert alert-light border mb-4">
                        <h6><i class="fas fa-shield-alt"></i> Password Requirements:</h6>
                        <ul class="mb-0 small">
                            <li>Minimum 12 characters</li>
                            <li>At least one uppercase letter (A-Z)</li>
                            <li>At least one lowercase letter (a-z)</li>
                            <li>At least one number (0-9)</li>
                            <li>At least one special character (!@@#$%^&* etc.)</li>
                            <li>Cannot reuse last 2 passwords</li>
                            <li>Minimum 2 minutes between password changes</li>
                            <li>Maximum password age: 5 minutes</li>
                        </ul>
                    </div>

                    <!-- Current Password Age -->
                    @if (Model.CurrentPasswordAgeMinutes > 0)
                    {
                        <div class="alert alert-secondary">
                            <i class="fas fa-clock"></i>
                            Current password age: <strong>@Model.CurrentPasswordAgeMinutes minutes</strong>
                            @if (Model.CurrentPasswordAgeMinutes >= 4)
                            {
                                <span class="text-warning fw-bold"> (Expiring soon!)</span>
                            }
                            else if (Model.CurrentPasswordAgeMinutes > 5)
                            {
                                <span class="text-danger fw-bold"> (EXPIRED!)</span>
                            }
                        </div>
                    }

                    <!-- Form -->
                    <form method="post" id="changePasswordForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Current Password -->
                        <div class="mb-3">
                            <label asp-for="Input.CurrentPassword" class="form-label">
                                <i class="fas fa-lock"></i> Current Password *
                            </label>
                            <input asp-for="Input.CurrentPassword" class="form-control" type="password" />
                            <span asp-validation-for="Input.CurrentPassword" class="text-danger small"></span>
                        </div>

                        <!-- New Password -->
                        <div class="mb-3">
                            <label asp-for="Input.NewPassword" class="form-label">
                                <i class="fas fa-key"></i> New Password *
                            </label>
                            <input asp-for="Input.NewPassword" class="form-control" type="password"
                                   id="newPassword" onkeyup="checkPasswordStrength()" />
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>

                            <!-- Password Strength Meter -->
                            <div class="mt-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <small>Strength:</small>
                                    <small id="passwordStrengthText" class="fw-bold">Very Weak</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div id="passwordStrengthBar" class="progress-bar" style="width: 0%;"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Confirm New Password -->
                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label">
                                <i class="fas fa-check-circle"></i> Confirm New Password *
                            </label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password"
                                   id="confirmPassword" onkeyup="checkPasswordMatch()" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            <small id="passwordMatch" class="text-muted"></small>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                <i class="fas fa-save"></i> Change Password
                            </button>
                            <a href="/" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-muted small">
                    <i class="fas fa-exclamation-triangle"></i> After changing password, you'll need to login again.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Password Strength Checker
        function checkPasswordStrength() {
            const password = document.getElementById('newPassword').value;
            const bar = document.getElementById('passwordStrengthBar');
            const text = document.getElementById('passwordStrengthText');
            const submitBtn = document.getElementById('submitBtn');

            // Check requirements
            const hasLength = password.length >= 12;
            const hasUpper = /[A-Z]/.test(password);
            const hasLower = /[a-z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSpecial = /[^A-Za-z0-9]/.test(password);

            // Calculate score (0-100)
            let score = 0;
            if (hasLength) score += 20;
            if (hasUpper) score += 20;
            if (hasLower) score += 20;
            if (hasNumber) score += 20;
            if (hasSpecial) score += 20;

            // Update progress bar
            bar.style.width = score + '%';

            // Set color and text
            if (score < 40) {
                bar.className = 'progress-bar bg-danger';
                text.textContent = 'Very Weak';
            } else if (score < 60) {
                bar.className = 'progress-bar bg-warning';
                text.textContent = 'Weak';
            } else if (score < 80) {
                bar.className = 'progress-bar bg-info';
                text.textContent = 'Good';
            } else if (score < 100) {
                bar.className = 'progress-bar bg-primary';
                text.textContent = 'Strong';
            } else {
                bar.className = 'progress-bar bg-success';
                text.textContent = 'Very Strong!';
            }

            // Enable/disable submit button
            const isStrongEnough = score >= 60;
            submitBtn.disabled = !isStrongEnough;
        }

        // Password Confirmation Checker
        function checkPasswordMatch() {
            const password = document.getElementById('newPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            const matchText = document.getElementById('passwordMatch');

            if (confirm.length === 0) {
                matchText.textContent = '';
            } else if (password === confirm) {
                matchText.textContent = '✓ Passwords match';
                matchText.className = 'text-success';
            } else {
                matchText.textContent = '✗ Passwords do not match';
                matchText.className = 'text-danger';
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            checkPasswordStrength();
            checkPasswordMatch();
        });
    </script>
}