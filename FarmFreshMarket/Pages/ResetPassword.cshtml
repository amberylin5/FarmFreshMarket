@page
@model FarmFreshMarket.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="card-title mb-0"><i class="fas fa-key"></i> Reset Your Password</h3>
                </div>
                <div class="card-body">
                    @if (Model.InvalidToken)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i> Invalid or expired reset link.
                            <a href="/ForgotPassword" class="alert-link">Request a new reset link</a>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle"></i> @TempData["ErrorMessage"]
                        </div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Input.Email" />
                        <input type="hidden" asp-for="Input.Token" />

                        <!-- New Password -->
                        <div class="mb-3">
                            <label asp-for="Input.NewPassword" class="form-label">
                                <i class="fas fa-key"></i> New Password *
                            </label>
                            <input asp-for="Input.NewPassword" class="form-control" type="password"
                                   id="newPassword" onkeyup="checkPasswordStrength()" />
                            <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>

                            <!-- Password Strength Meter -->
                            <div class="mt-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <small>Strength:</small>
                                    <small id="passwordStrengthText" class="fw-bold">Very Weak</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div id="passwordStrengthBar" class="progress-bar" style="width: 0%;"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Confirm New Password -->
                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label">
                                <i class="fas fa-check-circle"></i> Confirm New Password *
                            </label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password"
                                   id="confirmPassword" onkeyup="checkPasswordMatch()" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            <small id="passwordMatch" class="text-muted"></small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-save"></i> Reset Password
                            </button>
                            <a href="/Login" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Login
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-muted small">
                    <i class="fas fa-shield-alt"></i> Choose a strong password that you haven't used before.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Password Strength Checker
        function checkPasswordStrength() {
            const password = document.getElementById('newPassword').value;
            const bar = document.getElementById('passwordStrengthBar');
            const text = document.getElementById('passwordStrengthText');

            const hasLength = password.length >= 12;
            const hasUpper = /[A-Z]/.test(password);
            const hasLower = /[a-z]/.test(password);
            const hasNumber = /[0-9]/.test(password);
            const hasSpecial = /[^A-Za-z0-9]/.test(password);

            let score = 0;
            if (hasLength) score += 20;
            if (hasUpper) score += 20;
            if (hasLower) score += 20;
            if (hasNumber) score += 20;
            if (hasSpecial) score += 20;

            bar.style.width = score + '%';

            if (score < 40) {
                bar.className = 'progress-bar bg-danger';
                text.textContent = 'Very Weak';
            } else if (score < 60) {
                bar.className = 'progress-bar bg-warning';
                text.textContent = 'Weak';
            } else if (score < 80) {
                bar.className = 'progress-bar bg-info';
                text.textContent = 'Good';
            } else if (score < 100) {
                bar.className = 'progress-bar bg-primary';
                text.textContent = 'Strong';
            } else {
                bar.className = 'progress-bar bg-success';
                text.textContent = 'Very Strong!';
            }
        }

        function checkPasswordMatch() {
            const password = document.getElementById('newPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            const matchText = document.getElementById('passwordMatch');

            if (confirm.length === 0) {
                matchText.textContent = '';
            } else if (password === confirm) {
                matchText.textContent = '✓ Passwords match';
                matchText.className = 'text-success';
            } else {
                matchText.textContent = '✗ Passwords do not match';
                matchText.className = 'text-danger';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            checkPasswordStrength();
            checkPasswordMatch();
        });
    </script>
}