@page
@model FarmFreshMarket.Pages.AdminModel
@{
    ViewData["Title"] = "Admin Panel";
}

<nav class="navbar navbar-light bg-light mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Fresh Farm Market</a>
        <div>
            <a href="/" class="btn btn-outline-primary btn-sm">Home</a>
        </div>
    </div>
</nav>

<div class="container">
    <h1><i class="fas fa-shield-alt"></i> Admin Panel</h1>

    <div class="alert alert-success">
        <h4><i class="fas fa-check-circle"></i> Access Granted</h4>
        <p>You have administrator privileges.</p>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-clipboard-list"></i> Security Monitoring</h5>
                </div>
                <div class="card-body">
                    <p>View system activity and security logs.</p>
                    <a href="/AdminAudit" class="btn btn-info">
                        <i class="fas fa-history"></i> View Audit Logs
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-users"></i> User Management</h5>
                </div>
                <div class="card-body">
                    <p>Manage user accounts and sessions.</p>
                    <a href="/ManageSessions" class="btn btn-primary">
                        <i class="fas fa-desktop"></i> Manage Sessions
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Add this new card for 2FA Management -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0"><i class="fas fa-shield-alt"></i> Security Settings</h5>
                </div>
                <div class="card-body">
                    <p>Configure authentication and security policies.</p>
                    <a href="/Manage2FA" class="btn btn-warning">
                        <i class="fas fa-lock"></i> Manage 2FA
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
</div>